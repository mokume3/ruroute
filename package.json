{
  "name": "ruroute",
  "type": "module",
  "version": "0.4.0",
  "description": "A type-safe URL builder",
  "keywords": [
    "typescript",
    "url",
    "route",
    "builder"
  ],
  "author": "mokume3 <mokume.dev@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/mokume3/ruroute#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mokume3/ruroute.git"
  },
  "bugs": {
    "url": "https://github.com/mokume3/ruroute/issues"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "coverage": "vitest run --coverage",
    "bench": "vitest bench",
    "check": "tsgo --noEmit && biome check",
    "fix": "tsgo --noEmit && biome check --write",
    "release": "bumpp",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/node": "^26.0.1",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "@vitest/coverage-v8": "^4.1.9",
    "bumpp": "^11.1.0",
    "knip": "^6.23.0",
    "lefthook": "^2.1.9",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
